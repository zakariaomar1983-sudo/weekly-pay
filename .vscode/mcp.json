{
	"servers": {
		"LaunchDarkly+FM": {
			"url": "https://mcp.launchdarkly.com/mcp/fm",
			"headers": {},
			"type": "http"
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.0.4"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.4"
		}
	},
	"inputs": [
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}